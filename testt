                guideText: "Главный критерий разделения: <ul><li><b>ВВП (Валовой внутренний продукт)</b> — по <i>территориальному признаку</i> (все товары внутри страны независимо от гражданства производителей);</li><li><b>ВНП (Валовой национальный продукт)</b> — по <i>национальному признаку</i> (все товары, созданные гражданами/фирмами этой страны, независимо от того, где они находятся).</li></ul>Поэтому продукция иностранной фирмы на территории России включается в ВВП России, но НЕ включается в её ВНП.",
                cardTerm: "ВНП",
                cardDef: "Рыночная стоимость конечных товаров и услуг, созданных гражданами страны как внутри неё, так и за границей.",
                explain: "Иностранная фирма не принадлежит гражданам этой страны, следовательно, её результаты не входят в национальный продукт (ВНП).",
                hint: "ВНП измеряет доходы только граждан/фирм данной страны. Иностранцы сюда не входят."
            },
            {
                id: 12,
                q: "Инфляция издержек вызвана:",
                options: [
                    "Снижением налогов",
                    "Увеличением производительности труда",
                    "Ростом затрат на производство",
                    "Ростом денежных доходов населения"
                ],
                correctIndex: 2, // "Ростом затрат на производство"
                guideTitle: "К заданию 12. Инфляция издержек",
                guideText: "Инфляция по причинам возникновения бывает двух основных видов: <ol><li><b>Инфляция спроса</b> (избыток денег у населения, дефицит товаров);</li><li><b>Инфляция издержек (предложения)</b> — вызывается <i>ростом цен на ресурсы и сырьё</i>, увеличением налогов на бизнес или ростом зарплат. Производители вынуждены поднимать цены на конечные товары, чтобы покрыть возросшие затраты на производство.</li></ol>",
                cardTerm: "Инфляция издержек",
                cardDef: "Вид инфляции, возникающий вследствие роста цен на производственные ресурсы и сырье.",
                explain: "Инфляция издержек напрямую связана с увеличением себестоимости выпуска продукции.",
                hint: "Слово 'издержки' в экономике означает затраты на производство."
            }
        ];

        // Инициализация страниц
        function showPage(id) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.getElementById(id).classList.add('active');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // РЕНДЕР ТЕОРИИ (Справочник строго по заданиям)
        function initGuide() {
            const container = document.getElementById('guide-list');
            container.innerHTML = '';
            
            database.forEach(item => {
                const block = document.createElement('div');
                block.className = 'bg-white p-6 rounded-2xl border border-slate-200 shadow-sm hover:shadow transition';
                block.innerHTML = `
                    <h3 class="text-xl font-bold text-indigo-900 mb-3">${item.guideTitle}</h3>
                    <div class="text-slate-700 leading-relaxed text-sm space-y-2">
                        ${item.guideText}
                    </div>
                    <div class="mt-4 pt-3 border-t border-slate-100 flex justify-between items-center">
                        <span class="text-xs text-slate-400">Связано с вопросом №${item.id}</span>
                        <button onclick="goToQuestion(${item.id})" class="text-xs font-bold text-indigo-600 hover:underline">Проверить знания →</button>
                    </div>
                `;
                container.appendChild(block);
            });
        }

        function goToQuestion(id) {
            showPage('quiz');
            const targetEl = document.getElementById(`question-card-${id}`);
            if (targetEl) {
                setTimeout(() => {
                    targetEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    targetEl.classList.add('ring-2', 'ring-indigo-500');
                    setTimeout(() => targetEl.classList.remove('ring-2', 'ring-indigo-500'), 2000);
                }, 100);
            }
        }

        // РЕНДЕР КАРТОЧЕК
        function initCards() {
            const container = document.getElementById('cards-grid');
            container.innerHTML = '';

            // Разнообразные сочные фоны для карточек
            const colors = [
                { f: 'bg-gradient-to-br from-indigo-500 to-indigo-600', b: 'bg-gradient-to-br from-indigo-600 to-indigo-700' },
                { f: 'bg-gradient-to-br from-sky-500 to-sky-600', b: 'bg-gradient-to-br from-sky-600 to-sky-700' },
                { f: 'bg-gradient-to-br from-emerald-500 to-emerald-600', b: 'bg-gradient-to-br from-emerald-600 to-emerald-700' },
                { f: 'bg-gradient-to-br from-amber-500 to-amber-600', b: 'bg-gradient-to-br from-amber-600 to-amber-700' },
                { f: 'bg-gradient-to-br from-rose-500 to-rose-600', b: 'bg-gradient-to-br from-rose-600 to-rose-700' },
                { f: 'bg-gradient-to-br from-purple-500 to-purple-600', b: 'bg-gradient-to-br from-purple-600 to-purple-700' }
            ];

            database.forEach((item, index) => {
                const color = colors[index % colors.length];
                const cardWrapper = document.createElement('div');
                cardWrapper.className = 'perspective-1000 w-full h-56 cursor-pointer';
                cardWrapper.innerHTML = `
                    <div class="card-inner relative w-full h-full text-white shadow-md rounded-2xl" onclick="this.classList.toggle('flipped')">
                        <!-- Лицевая сторона -->
                        <div class="card-front absolute w-full h-full ${color.f} rounded-2xl p-6 flex flex-col justify-between">
                            <span class="text-xs uppercase tracking-wider opacity-75 font-bold">Карточка ${index + 1}</span>
                            <div class="text-lg font-black text-center my-auto">${item.cardTerm}</div>
                            <span class="text-xs text-right opacity-50">Нажми, чтобы перевернуть</span>
                        </div>
                        <!-- Обратная сторона -->
                        <div class="card-back absolute w-full h-full ${color.b} rounded-2xl p-6 flex flex-col justify-between">
                            <span class="text-xs uppercase tracking-wider opacity-75 font-bold">Определение</span>
                            <div class="text-sm font-semibold leading-relaxed text-center my-auto">${item.cardDef}</div>
                            <span class="text-xs text-right opacity-50">Нажми, чтобы перевернуть</span>
                        </div>
                    </div>
                `;
                container.appendChild(cardWrapper);
            });
        }

        // РЕНДЕР ТЕСТА
        let solvedQuestions = {}; // хранит состояние решенных вопросов
        let currentQuizData = [];

        function renderQuiz(shuffle = true) {
            const container = document.getElementById('quiz-container');
            container.innerHTML = '';
            
            // Клонируем базу данных, чтобы не менять оригинал при перемешивании
            currentQuizData = JSON.parse(JSON.stringify(database));
            if (shuffle) {
                currentQuizData.sort(() => Math.random() - 0.5);
            }

            solvedQuestions = {};
            updateScore();
            document.getElementById('quiz-footer').classList.add('hidden');

            currentQuizData.forEach((item, index) => {
                solvedQuestions[item.id] = false;

                const qCard = document.createElement('div');
                qCard.id = `question-card-${item.id}`;
                qCard.className = 'bg-white p-6 rounded-2xl border border-slate-200 shadow-sm transition-all duration-300';
                
                // Создаем разметку для вариантов ответов
                let optionsHtml = '';
                item.options.forEach((opt, oIdx) => {
                    optionsHtml += `
                        <button 
                            id="btn-${item.id}-${oIdx}"
                            onclick="checkAnswer(${item.id}, ${oIdx}, ${item.correctIndex}, '${item.explain.replace(/'/g, "\\'")}', '${item.hint.replace(/'/g, "\\'")}')"
                            class="option-btn block w-full text-left px-4 py-3 my-2 rounded-xl border border-slate-200 bg-slate-50 text-slate-700 hover:bg-indigo-50 hover:border-indigo-300 hover:text-indigo-900 transition font-medium text-sm"
                        >
                            ${opt}
                        </button>
                    `;
                });

                qCard.innerHTML = `
                    <div class="flex items-start gap-3 mb-4">
                        <span class="flex items-center justify-center bg-indigo-100 text-indigo-800 font-bold text-xs w-6 h-6 rounded-full shrink-0 mt-0.5">${index + 1}</span>
                        <h4 class="font-bold text-slate-900 text-base">${item.q}</h4>
                    </div>
                    <div class="space-y-1">
                        ${optionsHtml}
                    </div>
                    <!-- Блок обратной связи -->
                    <div id="feedback-${item.id}" class="mt-4 p-4 rounded-xl text-sm hidden"></div>
                `;
                container.appendChild(qCard);
            });
        }

        function checkAnswer(questionId, chosenIndex, correctIndex, explanation, hint) {
            const feedbackEl = document.getElementById(`feedback-${questionId}`);
            const chosenBtn = document.getElementById(`btn-${questionId}-${chosenIndex}`);
            
            if (chosenIndex === correctIndex) {
                // Если ответ верный
                solvedQuestions[questionId] = true;
                
                // Делаем верную кнопку зеленой
                chosenBtn.className = "option-btn block w-full text-left px-4 py-3 my-2 rounded-xl border border-emerald-500 bg-emerald-50 text-emerald-900 font-bold text-sm transition";
                
                // Отключаем остальные кнопки в этом вопросе
                const parent = chosenBtn.parentElement;
                const buttons = parent.querySelectorAll('.option-btn');
                buttons.forEach(btn => {
                    if (btn !== chosenBtn) {
                        btn.disabled = true;
                        btn.classList.add('opacity-50');
                    }
                });

                // Выводим красивое объяснение
                feedbackEl.className = "mt-4 p-4 rounded-xl text-sm bg-emerald-100 border border-emerald-200 text-emerald-900 block";
                feedbackEl.innerHTML = `<strong>✨ Верно!</strong> ${explanation}`;
                
                updateScore();
            } else {
                // Если ответ неверный
                chosenBtn.className = "option-btn block w-full text-left px-4 py-3 my-2 rounded-xl border border-rose-500 bg-rose-50 text-rose-900 font-medium text-sm transition";
                chosenBtn.disabled = true; // Отключаем именно эту ошибочную кнопку

                // Выводим подсказку, почему выбор неверен, и предлагаем подумать еще
                feedbackEl.className = "mt-4 p-4 rounded-xl text-sm bg-rose-100 border border-rose-200 text-rose-900 block";
                feedbackEl.innerHTML = `<strong>❌ Ошибка.</strong> ${hint} Попробуйте выбрать другой вариант!`;
            }
        }

        function updateScore() {
            const solvedCount = Object.values(solvedQuestions).filter(Boolean).length;
            const total = database.length;
            document.getElementById('score-counter').innerText = `Пройдено: ${solvedCount} / ${total}`;

            if (solvedCount === total) {
                document.getElementById('quiz-footer').classList.remove('hidden');
                document.getElementById('quiz-footer').scrollIntoView({ behavior: 'smooth' });
            }
        }

        function restartQuiz() {
            renderQuiz(true);
        }

        // Запуск при загрузке страницы
        window.onload = function() {
            initGuide();
            initCards();
            renderQuiz(true);
        };
    </script>
</body>
</html>
